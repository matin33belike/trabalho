generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client-logs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_LOGS_URL")
}

model Log {
  id        String   @id @default(uuid())
  descricao String
  data      DateTime @default(now())

  @@map("logs")
}
